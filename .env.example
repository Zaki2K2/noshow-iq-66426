# ─────────────────────────────────────────────────────────────
# .env.example — safe placeholder values ONLY
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Replace every <placeholder> with your real values.
#   3. NEVER commit the real .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGO_URI=mongodb://localhost:27017

# Name of the MongoDB database
MONGO_DB_NAME=noshow_iq

# Path to the serialised model file (relative to repo root)
MODEL_PATH=models/model.joblib

# Environment: development | testing | production
APP_ENV=development

# ── Docker-compose extras ────────────────────────────────────
# Used by docker-compose.yml to set the Mongo root credentials.
# These are ONLY for local dev — change before any real deployment.
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# ── CI/CD (set these in GitHub Actions Secrets, NOT here) ───
# DOCKER_HUB_USERNAME=<your-dockerhub-username>
# DOCKER_HUB_TOKEN=<your-dockerhub-access-token>
# HF_TOKEN=<your-huggingface-write-token>
# HF_SPACE=<your-hf-username>/<your-space-name>
